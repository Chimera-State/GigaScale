# === App Config ===
APP_ENV=development
SERVER_PORT=:8080

# === PostgreSQL Database ===
# Docker içerisindeki PostgreSQL servisi için (Container ortamı)
POSTGRES_USER=gigascale_user
POSTGRES_PASSWORD=test_password
POSTGRES_DB=gigascaledb
# Backend'in veritabanına bağlanması için gereken URL (Docker ağı içi)
DATABASE_URL=postgres://gigascale_user:test_password@postgres:5432/gigascaledb?sslmode=disable

# === Redis ===
REDIS_ADDR=redis:6379
USE_REDIS_LIMITER=true

# === Gateway ===
BACKEND_ADDR=backend:50051